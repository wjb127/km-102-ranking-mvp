# ── Neon PostgreSQL ─────────────────────────────
# Neon 콘솔 → Connection Details → "Pooled connection" 문자열 복사
# 예: postgresql://USER:PASS@HOST.neon.tech/DB?sslmode=require
DATABASE_URL=

# ── balldontlie MMA API ─────────────────────────
BALLDONTLIE_API_KEY=

# ── Auth.js (추후 추가) ─────────────────────────
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=your-secret-key-here

# ── Cloudinary (이미지 업로드 추후 추가) ────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── 번역 API (DeepL / Papago 추후 추가) ────────
# DEEPL_API_KEY=
